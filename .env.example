# ── GitHub ──────────────────────────────────────────────────────────────────
# Generate a token at: https://github.com/settings/tokens
# Required scopes: repo > contents (write)
# GitHub Personal Access Token (with 'repo' scope)
GITHUB_TOKEN=your_github_token_here

# Gmail SMTP Configuration for alerts
# 1. GMAIL_USER: Your full gmail address
# 2. GMAIL_APP_PASSWORD: A 16-character app password from Google Security settings
#    (NOT your regular gmail password)
# 3. NOTIFY_EMAIL: Where you want the alerts sent
GMAIL_USER=your_email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
NOTIFY_EMAIL=recipient@example.com

# Email that RECEIVES the alerts
NOTIFY_EMAIL=recipient@example.com
